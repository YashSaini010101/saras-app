# Copy to .env and fill in real values (never commit .env).

MONGODB_URI=mongodb://127.0.0.1:27017/saras
JWT_SECRET=your_long_random_secret_here

PORT=5000

# Gmail SMTP — must use an App Password (not your normal Gmail password):
# Google Account → Security → 2-Step Verification ON → App passwords → Mail / Other → copy 16 chars.
# Paste into EMAIL_PASS with or without spaces (we strip spaces).
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=abcdabcdabcdabcd

# Optional: lock CORS to your frontend URL in production
# CLIENT_URL=https://your-site.example
